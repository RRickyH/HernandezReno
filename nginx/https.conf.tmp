server {
    listen 443 ssl http2;
    server_name api.hernandezreno.ca;
    
    # SSL Certificate paths
    ssl_certificate /etc/letsencrypt/live/api.hernandezreno.ca/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.hernandezreno.ca/privkey.pem;
    
    # SSL Configuration (include Let's Encrypt recommended settings)
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    
    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    
    # Proxy to your Go backend
    location / {
        proxy_pass http://bluesteel:8080;  # Docker service name
        proxy_http_version 1.1;
        
        # Important headers for your backend
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        
        # WebSocket support (if needed later)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Buffer settings
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;
    }
}